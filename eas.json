{
	"cli": {
		"version": ">= 14.4.1",
		"appVersionSource": "remote"
	},
	"build": {
		"development": {
			"developmentClient": true,
			"distribution": "internal"
		},
		"preview": {
			"distribution": "internal"
		},
		"staging": {
			"distribution": "internal",
			"android": {
				"buildType": "apk"
			}
		},
		"production": {
			"autoIncrement": true,
			"environment": "production",
			"android": {
				"buildType": "apk"
			},
			"prebuildCommand": "yarn config set registry https://registry.npmjs.org"
		}
	},
	"submit": {}
}
