{
    "expo": {
        "name": "vip-mobile",
        "slug": "vip-mobile",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/images/icon.png",
        "scheme": "myapp",
        "userInterfaceStyle": "automatic",
        "platforms": [
            "android"
        ],
        "newArchEnabled": true,
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "./assets/images/icon.png",
                "backgroundColor": "#000000"
            },
            "package": "mobile.vipsst.com.br",
            "permissions": [
                "ACCESS_FINE_LOCATION",
                "ACCESS_COARSE_LOCATION",
                "FOREGROUND_SERVICE",
                "FOREGROUND_SERVICE_LOCATION",
                "ACCESS_BACKGROUND_LOCATION",
                "RECEIVE_BOOT_COMPLETED"
            ]
        },
        "plugins": [
            "expo-router",
            "expo-location",
            [
                "expo-splash-screen",
                {
                    "image": "./assets/images/icon.png",
                    "imageWidth": 200,
                    "resizeMode": "contain",
                    "backgroundColor": "#ffffff"
                }
            ],
            "expo-font",
            "expo-web-browser"
        ],
        "experiments": {
            "typedRoutes": true
        },
        "extra": {
            "router": {
                "origin": false
            },
            "eas": {
                "projectId": "ab38cd83-26ae-4e74-8228-e6f5e4b796eb"
            }
        },
        "ios": {
            "bundleIdentifier": "mobile.vipsst.com.br"
        }
    }
}
